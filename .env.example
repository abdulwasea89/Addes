# ─────────────────────────────────────────────────────────────
# AdForge Backend — Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# All values below are placeholders — replace before running.
# ─────────────────────────────────────────────────────────────

# ╔═══════════════════════════════════════════════════════════╗
# ║ 1. APP                                                    ║
# ╚═══════════════════════════════════════════════════════════╝
APP_ENV=development                # development | staging | production
FRONTEND_URL=http://localhost:3000 # used for CORS
LOG_LEVEL=info                     # debug | info | warning | error


# ╔═══════════════════════════════════════════════════════════╗
# ║ 2. SUPABASE — API keys                                    ║
# ╠═══════════════════════════════════════════════════════════╣
# ║ Supabase is migrating from JWT-based legacy keys to a new ║
# ║ sb_publishable_… / sb_secret_… scheme (rollout 2025+).    ║
# ║ Projects created before the rollout still have the legacy ║
# ║ "anon" and "service_role" keys — we accept BOTH.          ║
# ║                                                           ║
# ║ Fill EITHER the legacy block OR the new block. The app    ║
# ║ prefers the new keys when both are present.               ║
# ╚═══════════════════════════════════════════════════════════╝
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF

# — Legacy (still works on existing projects; safe default) —
SUPABASE_ANON_KEY=eyJhbGciOi...           # client-side, low privilege (was SUPABASE_KEY)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # server-side, ADMIN — never expose

# — New (preferred for projects created after Nov 2025) —
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# JWT verification (used by our auth middleware to validate
# tokens issued by Supabase Auth). Get from Supabase Dashboard
# → Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret


# ╔═══════════════════════════════════════════════════════════╗
# ║ 3. SUPABASE — Postgres (direct asyncpg connection)        ║
# ╠═══════════════════════════════════════════════════════════╣
# ║ Why this exists separately from the keys above:           ║
# ║ • SUPABASE_URL + keys talk to PostgREST (the REST API).   ║
# ║ • DATABASE_URL is a raw Postgres connection used by       ║
# ║   SQLAlchemy + asyncpg (spec §1, §10 require this).       ║
# ║ Both are needed: REST for auth/storage, raw for ORM CRUD. ║
# ║                                                           ║
# ║ Pick ONE of the three connection modes below.             ║
# ║ For this backend (FastAPI in a long-lived container) the  ║
# ║ Session Pooler is recommended — IPv4 friendly, supports   ║
# ║ prepared statements, no asyncpg quirks.                   ║
# ╚═══════════════════════════════════════════════════════════╝

# ── 3a. SESSION POOLER  (RECOMMENDED for this backend) ──
#   Port 5432 · IPv4 OK · prepared statements OK · long-lived OK
#   Region matches your project (e.g. us-east-1, ap-south-1).
DATABASE_URL=postgresql+asyncpg://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── 3b. TRANSACTION POOLER  (only for serverless / edge) ──
#   Port 6543 · no prepared statements · serverless workloads
#   IMPORTANT for asyncpg: append ?prepared_statement_cache_size=0
#   (and pass statement_cache_size=0 in asyncpg.connect)
# DATABASE_URL=postgresql+asyncpg://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# ── 3c. DIRECT CONNECTION  (IPv6 only by default) ──
#   Port 5432 · IPv6 · skip the pooler entirely
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres


# ╔═══════════════════════════════════════════════════════════╗
# ║ 4. SUPABASE — Storage                                     ║
# ╚═══════════════════════════════════════════════════════════╝
SUPABASE_STORAGE_BUCKET=ad-images  # bucket holding generated ad images


# ╔═══════════════════════════════════════════════════════════╗
# ║ 5. AI PROVIDERS                                           ║
# ╚═══════════════════════════════════════════════════════════╝
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
REPLICATE_API_KEY=your_replicate_api_key


# ╔═══════════════════════════════════════════════════════════╗
# ║ 6. CLOUDFLARE SCRAPING                                    ║
# ╚═══════════════════════════════════════════════════════════╝
CLOUDFLARE_API_KEY=your_cloudflare_api_key
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
